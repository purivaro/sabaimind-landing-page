# Copy to .env.local and fill in. Set the same values in Vercel → Settings → Environment Variables.

# --- Database (Neon / Vercel Postgres) ---
# Neon: create a project at https://neon.tech and copy the pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js (Google OAuth) ---
# Generate a secret: `npx auth secret`  (or: openssl rand -base64 32)
AUTH_SECRET=""
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://sabaimind.or.jp/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Comma-separated emails allowed into /admin (the blog authors/editors).
ADMIN_EMAILS="you@example.com"

# --- Vercel Blob (uploaded images) ---
# Vercel dashboard → Storage → Blob → create store → copy the read-write token.
BLOB_READ_WRITE_TOKEN=""

# --- AI features ---
# Draft writing (Claude): https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Image generation (OpenAI): https://platform.openai.com
OPENAI_API_KEY=""

# --- Registration emails (Resend, optional) ---
# Confirmation + team notification emails on new registrations. If unset, registrations still save (no email).
RESEND_API_KEY=""
# Verified sender, e.g. "Sabai Mind <noreply@sabaimind.or.jp>"
RESEND_FROM_EMAIL=""
# Comma-separated team recipients (defaults to ADMIN_EMAILS if unset)
REGISTRATION_TEAM_EMAILS=""
